# =============================================================================
# Shopify Storefront API (PUBLIC — safe to ship in client-side bundle)
# =============================================================================
# Get these from the Shopify Headless app:
#   Settings → Apps → Headless → your storefront → Storefront API
#
# Public Storefront tokens are designed to be exposed to the browser.
# Do NOT use the Admin API token here.

# Your shop's myshopify.com domain (no protocol, no trailing slash)
VITE_SHOPIFY_STORE_DOMAIN=giggle-kids.myshopify.com

# Public Storefront API access token
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Storefront API version (defaults to 2024-10 — bump every 3 months or so)
VITE_SHOPIFY_API_VERSION=2024-10
