# =============================================================================
# Shopify Storefront API (PUBLIC — safe to ship in client-side bundle)
# =============================================================================
# Get these from your Shopify admin:
#   Settings → Apps and sales channels → Develop apps → (your app) → API credentials
# Make sure the app has the "Storefront API access" scope enabled.

# Your shop's myshopify.com domain (no protocol, no trailing slash)
VITE_SHOPIFY_STORE_DOMAIN=giggle-kids.myshopify.com

# Public Storefront API access token
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Storefront API version (defaults to 2024-10 — bump every 3 months)
VITE_SHOPIFY_API_VERSION=2024-10


# =============================================================================
# Shopify Customer Account API (NEW — replaces legacy Customer API)
# =============================================================================
# Get these from your Shopify admin:
#   Settings → Customer accounts → Headless → Customer Account API
# Enable "Allow customers to log in with their account"

# Numeric shop ID (NOT the .myshopify.com domain) — found in the Customer
# Account API setup page in Shopify admin
VITE_SHOPIFY_SHOP_ID=

# Public client ID for the Customer Account API
VITE_SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=

# OAuth callback URL — must match what's configured in Shopify
# Local dev:  http://localhost:5173/account/callback
# Production: https://yourdomain.com/account/callback
VITE_SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=http://localhost:5173/account/callback
