# =============================================================================
# Shopify Storefront API (PUBLIC — safe to ship in client-side bundle)
# =============================================================================
# Get these from the Shopify Headless app:
#   Settings → Apps → Headless → your storefront → Storefront API
#
# Public Storefront tokens are designed to be exposed to the browser.
# Do NOT use the Admin API token here.

# IMPORTANT: this MUST be your *.myshopify.com subdomain, NOT your custom
# domain (e.g. NOT gigglekidsllc.com). The Storefront API base URL is
# constructed as `https://{this}/api/{version}/graphql.json` — for that
# to work, the domain has to point to a Shopify backend.
# Find it in Shopify admin → Settings → Domains (top of page).
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Public Storefront API access token (starts with "shpat_" usually)
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Storefront API version. Default is current stable. Shopify ships a new
# version quarterly and supports each one for ~12 months — bump occasionally.
VITE_SHOPIFY_API_VERSION=2026-04
